[DEBUG] Raw row from DB: (41722578, "When Alzheimer's disease prevention becomes policy: regulatory speed, commercialisation, and risk.", 'The Lancet. Neurology', datetime.date(2026, 3, 1), None, datetime.datetime(2026, 2, 22, 16, 27, 39, 356799, tzinfo=zoneinfo.ZoneInfo(key='America/New_York')), '', None)
