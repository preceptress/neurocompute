[DEBUG] Raw row from DB: (41729309, "Shunt surgery and lecanemab therapy in patients with idiopathic normal pressure hydrocephalus and alzheimer's disease: a report of two cases.", 'Acta neurochirurgica', datetime.date(2026, 2, 23), None, datetime.datetime(2026, 2, 24, 2, 0, 23, 187425, tzinfo=zoneinfo.ZoneInfo(key='America/New_York')), "Idiopathic normal pressure hydrocephalus (iNPH) is a condition in the elderly commonly treated with ventriculoperitoneal (VP) or lumboperitoneal (LP) shunt surgery. iNPH frequently coexists with Alzheimer's disease (AD), for which anti-amyloid-β antibodies such as lecanemab have recently become available. Because lecanemab may cause hemorrhagic imaging abnormalities, the timing of shunt surgery in relation to antibody therapy raises concern regarding perioperative bleeding risk. Here, we report two patients with iNPH and AD treated with different sequences of shunt surgery and lecanemab. No hemorrhagic complications were observed, although conclusions regarding safety should be interpreted cautiously.", None)
[DEBUG] Paper dict: {'pmid': 41729309, 'title': "Shunt surgery and lecanemab therapy in patients with idiopathic normal pressure hydrocephalus and alzheimer's disease: a report of two cases.", 'journal': 'Acta neurochirurgica', 'publication_date': datetime.date(2026, 2, 23), 'score': None, 'created_at': datetime.datetime(2026, 2, 24, 2, 0, 23, 187425, tzinfo=zoneinfo.ZoneInfo(key='America/New_York')), 'abstract': "Idiopathic normal pressure hydrocephalus (iNPH) is a condition in the elderly commonly treated with ventriculoperitoneal (VP) or lumboperitoneal (LP) shunt surgery. iNPH frequently coexists with Alzheimer's disease (AD), for which anti-amyloid-β antibodies such as lecanemab have recently become available. Because lecanemab may cause hemorrhagic imaging abnormalities, the timing of shunt surgery in relation to antibody therapy raises concern regarding perioperative bleeding risk. Here, we report two patients with iNPH and AD treated with different sequences of shunt surgery and lecanemab. No hemorrhagic complications were observed, although conclusions regarding safety should be interpreted cautiously.", 'summary_1': ''}
